evantes: # verificação se a palavra não está na lista de palavras irrelevantes\n","         nova_frase.append(palavra) # se não for irrelevante, salvar na lista 'nova_frase'\n","  \n","     frase_processada.append(' '.join(nova_frase))  # ao terminar uma linha da base, juntar as palavras separando-as com espaço (' ') como em uma frase\n","\n","resenha['tratamento_1'] = frase_processada  # criar coluna com as novas frases processadas sem palavras irrelevantes na nova coluna 'tratamento_1'"],"execution_count":24,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"smBLKyoUYpMm"},"source":["## Acurácia da análise **com tratamento de dados 1**: 66%"]},{"cell_type":"code","metadata":{"id":"km3W_v7qKGbR","executionInfo":{"status":"ok","timestamp":1603476441302,"user_tz":180,"elapsed":174283,"user":{"displayName":"Vitor Balbuglio","photoUrl":"https://lh3.googleusercontent.com/a-/AOh14GhpB3FwLuLzFZy35D03UlErezlJaTaeVPA0FJqwQHo=s64","userId":"12521679878525296138"}},"outputId":"856df1a3-debb-4e1e-d033-d3793a194349","colab":{"base_uri":"https://localhost:8080/","height":514}},"source":["print(classificar_texto(resenha, 'tratamento_1', 'classificacao'))\n","pareto(resenha, 'tratamento_1', 10)"],"execution_count":25,"outputs":[{"output_type":"stream","text":["0.6607359482410028\n"],"name":"stdout"},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<Figure size 864x576 with 1 Axes>"]},"metadata":{"tags":[],"needs_background":"light"}}]}]}