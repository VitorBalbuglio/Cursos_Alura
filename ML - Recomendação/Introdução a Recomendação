s em comum que os usuários tem\n","    return None                  # aqui refazemos a função para evitar retornar usuários distantes com nota 100000 como implementado antes\n","    \n","  distancia = distancia_de_vetores(diferencas['nota_esquerda'], diferencas['nota_direita']) # calculo a distância entre os usuários\n","  return [usuario_id1, usuario_id2, distancia]  # retorno uma lista com colunas do primeiro usuário, segundo usuário e a distância entre eles\n","\n","\n","def distancia_de_todos(voce_id, numero_de_usuarios_a_analisar = None):\n","  todos_os_usuarios = notas['usuarioId'].unique() # busco quais usuários tem em notas (aparição única)\n","\n","  if numero_de_usuarios_a_analisar:\n","    todos_os_usuarios = todos_os_usuarios[:numero_de_usuarios_a_analisar] # caso fornecido a # de usuários a analisar, filtro pra essa quantidade\n","\n","  distancias = [distancia_de_usuarios(voce_id, usuario_id) for usuario_id in todos_os_usuarios] # calculo a distância para todos os usuarios dentro do grupo de usuarios apra analisar\n","  distancias = list(filter(None, distancias)) # remover dos resultados os usuarios que têm distâncias maior que o mínimo definido em 'distancia_de_usuarios'\n","  distancias = pd.DataFrame(distancias, columns=['voce', 'outra_pessoa', 'distancia'])  # crio df com a distância de você para todos os analisados com a respectiva distância\n","  return distancias\n","\n","\n","def knn(voce_id, k_mais_proximos = 10, numero_de_usuarios_a_analisar = None):\n","  distancias = distancia_de_todos(voce_id, numero_de_usuarios_a_analisar = numero_de_usuarios_a_analisar) # retorno da função 'distancia_de_todos'\n","  distancias = distancias.sort_values('distancia')  # ordenar da menor pra maior distância\n","  distancias = distancias.set_index('outra_pessoa').drop(voce_id) # setar o indice como sendo 'outra_pessoa' e elimina a própria pessoa da lista (distancia=0)\n","  return distancias.head(k_mais_proximos)\n","\n","\n","def sugere_para(voce, k_mais_proximos = 10, numero_de_usuarios_a_analisar = None):\n","  notas_de_voce = notas_do_usuario(voce) # pega as notas que você deu\n","  filmes_que_voce_ja_viu = notas_de_voce.index  # pego os filmes que você deu nota\n","\n","  similares = knn(voce, k_mais_proximos = k_mais_proximos, numero_de_usuarios_a_analisar = numero_de_usuarios_a_analisar)  # pega as pessoas similares a você\n","  usuarios_similares = similares.index  # pego os índices dos usuários similares\n","  notas_dos_similares = notas.set_index('usuarioId').loc[usuarios_similares] # busco as notas dos usuários similares\n","\n","  recomendacoes = notas_dos_similares.groupby('filmeId').mean()[['nota']] # agrupo por filme e calcula a média por filme, dentro do grupo de similares\n","  recomendacoes = recomendacoes.sort_values('nota', ascending = False)  # faço a ordenação em ordem decrescente \n","  return recomendacoes.join(filmes) # retorno um df com a lista de filmes unidas às recomendações"],"execution_count":42,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"VPeaCQTj2Pmv"},"source":["Exemplo de utilização"]},{"cell_type":"code","metadata":{"id":"j4iuo3qkwGWT","executionInfo":{"status":"ok","timestamp":1603934659897,"user_tz":180,"elapsed":53550,"user":{"displayName":"Vitor Balbuglio","photoUrl":"https://lh3.googleusercontent.com/a-/AOh14GhpB3FwLuLzFZy35D03UlErezlJaTaeVPA0FJqwQHo=s64","userId":"12521679878525296138"}},"outputId":"8e31fef3-6e86-41b0-b1ad-3164ef7137a4","colab":{"base_uri":"https://localhost:8080/","height":235}},"source":["sugere_para(5, k_mais_proximos = 5, numero_de_usuarios_a_analisar = 250).head()"],"execution_count":43,"outputs":[{"output_type":"execute_result","data":{"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table bor